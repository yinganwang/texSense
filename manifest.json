{
  "manifest_version": 3,
  "name": "TexSense | Real-Time Overleaf Latex Word Count",
  "version": "1.0.0",
  "description": "Real-time word count for Overleaf LaTeX documents.",
  "content_scripts": [
    {
      "matches": ["https://www.overleaf.com/*"],
      "js": ["contentScript.js"],
      "css": ["styles.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://www.overleaf.com/*"]
    }
  ],
  "host_permissions": ["https://www.overleaf.com/*"]
}
